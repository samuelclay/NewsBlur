{
    "service": {
        "name": "db-mongo-analytics",
        "id": "{{ inventory_hostname }}-analytics",
        "tags": [
            "db"
        ],
        "port": 27018,
        "checks": [{
            "id": "mongo-analytics-ping",
            "http": "http://{{ ansible_host }}:5579/db_check/mongo_analytics?consul=1",
            "interval": "15s"
        }]
    }
}
