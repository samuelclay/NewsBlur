<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="10dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <View
        android:id="@+id/sheet_drag_handle"
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/sheet_title"
        style="?defaultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/menu_sharenewsblur"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/story_title"
        style="?storyTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/comment_field"
        style="?defaultText"
        android:layout_width="match_parent"
        android:layout_height="144dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:gravity="top|start"
        android:hint="@string/share_comment_hint"
        android:importantForAutofill="no"
        android:inputType="textCapSentences|textMultiLine"
        android:maxLines="8"
        android:minLines="6"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp"
        android:scrollbarStyle="outsideInset"
        android:singleLine="false"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/button_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/secondary_button"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:paddingHorizontal="10dp"
            android:text="@string/alert_dialog_cancel"
            android:textAllCaps="false"
            app:cornerRadius="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/primary_button"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:minWidth="120dp"
            android:text="@string/share_this_story"
            android:textAllCaps="false"
            app:cornerRadius="6dp" />

    </LinearLayout>

</LinearLayout>
