# Auto-generated workspace-specific docker-compose file
# Workspace: {{ workspace_name }}
# Standalone compose file for workspace services only

services:
  newsblur_web:
    container_name: newsblur_web_{{ workspace_name }}
    hostname: nb-{{ workspace_name }}.com
    image: newsblur/newsblur_python3:latest
    environment:
      - DOCKERBUILD=True
      - RUNWITHMAKEBUILD=${RUNWITHMAKEBUILD:-True}
      - NEWSBLUR_WORKTREE={{ workspace_name }}
    stdin_open: true
    tty: true
    restart: "no"
    ulimits:
      nproc: 10000
      nofile:
        soft: 10000
        hard: 10000
    ports:
      - {{ web_port }}:8000
    entrypoint: /bin/sh -c newsblur_web/entrypoint.sh
    volumes:
      - ${PWD}:/srv/newsblur
    networks:
      - default
      - newsblur_default

  newsblur_node:
    container_name: newsblur_node_{{ workspace_name }}
    image: newsblur/newsblur_node:latest
    user: "${CURRENT_UID:-1000}:${CURRENT_GID:-1000}"
    environment:
      - NODE_ENV=docker
      - MONGODB_PORT=29019
    command: node newsblur.js
    restart: "no"
    stop_signal: HUP
    ports:
      - {{ node_port }}:8008
    volumes:
      - ${PWD}/node:/srv
      - ${PWD}/node/originals:/srv/originals
    networks:
      - default
      - newsblur_default

  nginx:
    container_name: newsblur_nginx_{{ workspace_name }}
    image: nginx:1.19.6
    restart: "no"
    ports:
      - {{ nginx_port }}:81
    depends_on:
      - newsblur_web
      - newsblur_node
    environment:
      - DOCKERBUILD=True
    volumes:
      - ${PWD}/docker/nginx/nginx.local.conf:/etc/nginx/conf.d/nginx.conf
      - ${PWD}:/srv/newsblur
    networks:
      - default
      - newsblur_default
    healthcheck:
      test: ["CMD-SHELL", "[ -f /var/run/nginx.pid ] && kill -0 $$(cat /var/run/nginx.pid)"]
      interval: 2s
      timeout: 2s
      retries: 3
      start_period: 5s

  haproxy:
    container_name: newsblur_haproxy_{{ workspace_name }}
    image: haproxy:latest
    restart: on-failure
    depends_on:
      nginx:
        condition: service_healthy
      newsblur_web:
        condition: service_started
      newsblur_node:
        condition: service_started
    ports:
      - {{ haproxy_http_port }}:80
      - {{ haproxy_https_port }}:443
      - {{ haproxy_stats_port }}:1936
    volumes:
      - ${PWD}/.worktree/haproxy/haproxy.{{ workspace_name }}.cfg:/usr/local/etc/haproxy/haproxy.cfg
      - ${PWD}:/srv/newsblur
    networks:
      - default
      - newsblur_default

  newsblur_mcp:
    container_name: newsblur_mcp_{{ workspace_name }}
    build:
      context: ../newsblur_mcp
    restart: "no"
    environment:
      - PYTHONPATH=/srv/newsblur_mcp
      - NEWSBLUR_BASE_URL=http://host.docker.internal:{{ haproxy_http_port }}
      - MCP_PORT=8099
      - MCP_HOST=0.0.0.0
      - MCP_OAUTH_CLIENT_ID=newsblur-mcp-server
      - MCP_OAUTH_CLIENT_SECRET=newsblur-mcp-dev-secret
      - MCP_OAUTH_BASE_URL=http://localhost:{{ haproxy_http_port }}/mcp
      - MCP_OAUTH_UPSTREAM_URL=http://localhost:{{ haproxy_http_port }}
      - MCP_OAUTH_INTERNAL_URL=http://host.docker.internal:{{ haproxy_http_port }}
    volumes:
      - ${PWD}/newsblur_mcp/newsblur_mcp:/srv/newsblur_mcp/newsblur_mcp
    depends_on:
      - newsblur_web
    networks:
      - default
      - newsblur_default

  task_celery:
    container_name: newsblur_celery_{{ workspace_name }}
    image: newsblur/newsblur_python3
    user: "${CURRENT_UID:-1000}:${CURRENT_GID:-1000}"
    command: "celery -A newsblur_web worker -B -s /srv/newsblur/logs/celerybeat-schedule-{{ workspace_name }}.db -Q {{ workspace_name }}_work_queue,{{ workspace_name }}_new_feeds,{{ workspace_name }}_push_feeds,{{ workspace_name }}_cron_queue,{{ workspace_name }}_beat_feeds_task,{{ workspace_name }}_search_indexer,{{ workspace_name }}_discover_indexer,{{ workspace_name }}_ask_ai --loglevel=INFO"
    restart: "no"
    volumes:
      - ${PWD}:/srv/newsblur
    environment:
      - DOCKERBUILD=True
      - NEWSBLUR_WORKTREE={{ workspace_name }}
    networks:
      - default
      - newsblur_default

networks:
  newsblur_default:
    external: true
    name: newsblur_default
